---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import ProjectCard from '../../components/ProjectCard.vue';

const projects = await getCollection('projects', ({ data }) => !data.draft);
const sortedProjects = projects.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const active = sortedProjects.filter(p => p.data.isActive);
const completed = sortedProjects.filter(p => !p.data.isActive);
---

<Layout title="Projects · CyberspaceLab">

  <!-- Page hero -->
  <div class="csl-page-hero" style="background-image: url('/assets/images/background/prague_eerie.png'); background-size: cover; background-position: center;">
    <div class="csl-page-hero-bg"></div>
    <div class="csl-container csl-page-hero-inner">
      <div class="csl-eyebrow" style="margin-bottom: 10px;">// Active research</div>
      <h1 style="font-family: var(--csl-font-heading); font-size: clamp(40px, 6vw, 72px); margin: 0; color: var(--csl-fg-1);">Projects</h1>
    </div>
  </div>

  <section class="csl-section">
    <div class="csl-container">
      {active.length > 0 && (
        <>
          <div class="csl-section-head">
            <div class="csl-eyebrow" style="margin-bottom: 12px;">// Ongoing</div>
            <div class="csl-section-title">
              <h2>Active projects</h2>
              <div class="csl-bar"></div>
            </div>
          </div>
          <div class="csl-grid-3" style="margin-bottom: 48px;">
            {active.map(project => (
              <ProjectCard data={project} client:visible />
            ))}
          </div>
        </>
      )}

      {completed.length > 0 && (
        <>
          <div class="csl-section-head">
            <div class="csl-eyebrow" style="margin-bottom: 12px;">// Completed</div>
            <div class="csl-section-title">
              <h2>Past projects</h2>
              <div class="csl-bar"></div>
            </div>
          </div>
          <div class="csl-grid-3">
            {completed.map(project => (
              <ProjectCard data={project} client:visible />
            ))}
          </div>
        </>
      )}
    </div>
  </section>

</Layout>

<style>
@media (max-width: 620px) {
  .csl-grid-3[style] { margin-bottom: 28px !important; }
}
</style>
