---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const teamMembers = await getCollection('team');
  return teamMembers.map(member => ({
    params: { slug: member.data.slug },
    props: { member },
  }));
}

const { member } = Astro.props as any;
const { Content } = await render(member);

const allProjects = await getCollection('projects', ({ data }: any) => !data.draft);
const memberProjects = allProjects.filter((project: any) =>
  project.data.memberSlugs.includes(member.data.slug)
);
const d = member.data;
const initials = d.title.split(' ').map((w: string) => w[0]).slice(0, 2).join('');
---

<Layout title={`${d.title} · CyberspaceLab`}>

  <section class="member-profile">
    <div class="csl-container">

      <!-- TOP BLOCK: portrait left, identity + bio right -->
      <div class="member-top">

        <!-- Portrait column -->
        <div class="member-portrait-col">
          <div class="member-portrait-frame">
            {d.featuredImage
              ? <img src={d.featuredImage} alt={d.title} />
              : <div class="member-initials">{initials}</div>
            }
          </div>

          {d.social && (
            <div class="member-socials">
              {d.social.twitter && <a href={d.social.twitter} class="csl-btn ghost" target="_blank" rel="noopener noreferrer">Twitter ↗</a>}
              {d.social.linkedin && <a href={d.social.linkedin} class="csl-btn ghost" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>}
              {d.social.researchgate && <a href={d.social.researchgate} class="csl-btn ghost" target="_blank" rel="noopener noreferrer">ResearchGate ↗</a>}
            </div>
          )}
        </div>

        <!-- Identity + bio column -->
        <div class="member-bio-col">
          <div class="csl-eyebrow" style="margin-bottom: 8px;">// Team member</div>
          <h1 class="member-name">{d.title}</h1>
          <div class="member-level">{d.level || d.role}</div>

          {d.expertise && d.expertise.length > 0 && (
            <div class="member-expertise">
              {d.expertise.map((tag: string) => (
                <span class="csl-tag">{tag}</span>
              ))}
            </div>
          )}

          <div class="csl-prose member-prose">
            <Content />
          </div>
        </div>
      </div>

      <!-- BOTTOM STRIP: meta facts in horizontal panels -->
      <div class="member-meta-strip">

        {d.education && d.education.length > 0 && (
          <div class="member-meta-block">
            <div class="csl-eyebrow member-meta-label">Education</div>
            <ul class="member-meta-list">
              {d.education.map((e: string) => <li>{e}</li>)}
            </ul>
          </div>
        )}

        {memberProjects.length > 0 && (
          <div class="member-meta-block">
            <div class="csl-eyebrow member-meta-label">Projects</div>
            <ul class="member-meta-list">
              {memberProjects.map((project: any) => (
                <li><a href={`/project/${project.data.slug}`} class="member-proj-link">{project.data.shortname || project.data.title}</a></li>
              ))}
            </ul>
          </div>
        )}

        {d.favoriteGames && d.favoriteGames.length > 0 && (
          <div class="member-meta-block">
            <div class="csl-eyebrow member-meta-label">Favorite games</div>
            <ul class="member-meta-list">
              {d.favoriteGames.map((g: string) => <li>{g}</li>)}
            </ul>
          </div>
        )}

        {d.hobbies && d.hobbies.length > 0 && (
          <div class="member-meta-block">
            <div class="csl-eyebrow member-meta-label">Hobbies</div>
            <ul class="member-meta-list">
              {d.hobbies.map((h: string) => <li>{h}</li>)}
            </ul>
          </div>
        )}

      </div>

    </div>
  </section>

</Layout>

<style>
/* ── Section shell ─────────────────────────────────────────── */
.member-profile {
  padding: 72px 0 96px;
}

/* ── Top block: portrait | bio ─────────────────────────────── */
.member-top {
  display: grid;
  grid-template-columns: 260px 1fr;
  gap: 48px;
  align-items: start;
  margin-bottom: 56px;
}

/* Portrait column */
.member-portrait-col {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.member-portrait-frame {
  position: relative;
  aspect-ratio: 3 / 4;
  overflow: hidden;
  border: 1px solid var(--csl-line);
  background: var(--csl-panel);
  clip-path: polygon(0 0, 100% 0, 100% calc(100% - 18px), calc(100% - 18px) 100%, 0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}
.member-portrait-frame img {
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: center top;
}
.member-initials {
  font-family: var(--csl-font-display);
  font-size: 80px;
  color: var(--csl-cyan);
  text-shadow: 0 0 24px rgba(0,240,255,0.5);
  user-select: none;
}

.member-socials {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.member-socials .csl-btn {
  width: 100%;
  justify-content: center;
  font-size: 12px;
  padding: 9px 16px;
}

/* Bio column */
.member-name {
  font-family: var(--csl-font-heading);
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 700;
  color: var(--csl-fg-1);
  margin: 0 0 8px;
  line-height: 1.1;
}

.member-level {
  font-family: var(--csl-font-mono);
  font-size: 12px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--csl-cyan);
  margin-bottom: 18px;
}

.member-expertise {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 24px;
}

.member-prose {
  max-width: 72ch;
}

/* ── Bottom meta strip ─────────────────────────────────────── */
.member-meta-strip {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 0;
  border-top: 1px solid var(--csl-line);
  border-left: 1px solid var(--csl-line);
}

.member-meta-block {
  padding: 22px 24px;
  border-right: 1px solid var(--csl-line);
  border-bottom: 1px solid var(--csl-line);
}

.member-meta-label {
  margin-bottom: 12px;
  color: var(--csl-violet);
}

.member-meta-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 5px;
}
.member-meta-list li {
  font-family: var(--csl-font-body);
  font-size: 14px;
  line-height: 1.4;
  color: var(--csl-fg-2);
  padding-left: 10px;
  position: relative;
}
.member-meta-list li::before {
  content: "·";
  position: absolute;
  left: 0;
  color: var(--csl-fg-4);
}

.member-proj-link {
  color: var(--csl-cyan);
  text-decoration: none;
  border-bottom: 1px solid rgba(0,240,255,0.3);
  padding-bottom: 1px;
  transition: color 220ms, border-color 220ms;
}
.member-proj-link:hover {
  color: var(--csl-magenta);
  border-bottom-color: var(--csl-magenta);
}

/* ── Responsive ────────────────────────────────────────────── */
@media (max-width: 720px) {
  .member-top {
    grid-template-columns: 1fr;
    gap: 28px;
  }
  .member-portrait-frame {
    aspect-ratio: 1 / 1;
    max-width: 260px;
  }
  .member-socials {
    flex-direction: row;
    flex-wrap: wrap;
  }
  .member-socials .csl-btn {
    width: auto;
  }
}
</style>
