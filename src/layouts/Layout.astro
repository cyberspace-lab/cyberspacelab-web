---
import Header from '../components/Header.vue';
import Footer from '../components/Footer.vue';
import siteConfig from '../config';
import "../assets/css/csl-design.css"

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  article?: boolean;
}

const {
  title,
  description = siteConfig.meta.description,
  image = siteConfig.meta.image,
  type = 'website',
  article = false
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, siteConfig.meta.siteUrl);
const seo = {
  title: title || siteConfig.meta.title,
  description: description || siteConfig.meta.description,
  image: `${siteConfig.meta.siteUrl}${image || siteConfig.meta.image}`,
  url: canonicalURL,
}
---

<!DOCTYPE html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <link rel="icon" type="image/png" href="/assets/images/favicon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta name="image" content={seo.image} />

    <!-- Alternate Languages -->
    <link rel="alternate" href={seo.url} hreflang="en-us" />
    <link rel="alternate" href={seo.url} hreflang="en" />
    <link rel="alternate" href={seo.url} hreflang="x-default" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={article ? 'article' : type} />
    <meta property="og:url" content={seo.url} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={seo.image} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    {siteConfig.meta.twitterUsername && (
      <meta name="twitter:creator" content={siteConfig.meta.twitterUsername} />
    )}
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={seo.image} />

    <!-- Theme init — runs before paint to prevent flash -->
    <script is:inline>
      try {
        var t = localStorage.getItem("csl-theme");
        if (t === "light" || t === "dark") {
          document.documentElement.setAttribute("data-theme", t);
        }
      } catch(e) {}
    </script>
  </head>

  <body>
    <div class="primary-container">
      <Header client:load />
      <slot />
      <Footer data={siteConfig.meta} client:visible />
    </div>
  </body>
</html>
